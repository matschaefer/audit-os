# Example environment variables for local development
# Do not commit real secrets.

# "demo"       -> public build, fictional data only, login optional
# "production" -> private workspace, login required for everything but "/"
NEXT_PUBLIC_APP_ENV=demo

# Clerk (https://dashboard.clerk.com) — leave unset to run without auth.
# The publishable key is safe for the client bundle (NEXT_PUBLIC_ prefix is
# intentional and required by Clerk); the secret key must never be exposed
# to the browser and must never carry a NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
